# === Incluir APENAS frontend/ e backend/ ===
# Ignorar tudo na raiz, exceto o que é explicitamente permitido
/*
!frontend/
!backend/
!.gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg

# Ambiente virtual
venv/
.venv/
env/

# Variáveis de ambiente
.env

# Config local do frontend (cada máquina tem o seu)
frontend/js/config.js

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Logs
*.log

# Arquivos locais do backend
backend/.env.example
backend/.streamlit/
backend/migrations/001_refatoracao_checklist_producao.sql
backend/migrations/backup_pre_refatoracao.sql
